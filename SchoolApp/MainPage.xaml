<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20">

            <!-- L15 Name Card -->

            <Label
                Text="Name card"
                FontSize="22"
                FontAttributes="Bold" />

            <Entry
                Text="{Binding Name}"
                Placeholder="Edit your name" />

            <Label
                Text="{Binding Name}"
                FontSize="20" />

            <Label
                Text="{Binding City}"
                FontSize="16"
                TextColor="Gray" />

            <!-- L14 Button -->

            <Button
                Text="Open students list"
                Clicked="OnOpenStudentsClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>